    "@fils/phy": "^0.0.7",
    "@fils/phy-three": "^0.0.6",
    "@fils/utils": "^0.1.6",
    "gsap": "^3.15.0",
    "p2-es": "^1.2.3",
    "simplex-noise": "^4.0.3",
    "three": "^0.183.2",
    "troika-three-text": "^0.52.4"
  },
  "devDependencies": {
    "@11ty/eleventy": "^3.1.5",
    "@11ty/eleventy-plugin-syntaxhighlight": "^5.0.2",
    "autoprefixer": "^10.4.27",
    "chokidar": "^5.0.0",
    "clean-css": "^5.3.3",
    "dotenv": "^17.4.1",
    "esbuild": "^0.28.0",
